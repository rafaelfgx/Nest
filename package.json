{
    "name": "nest",
    "version": "1.0.0",
    "dependencies": {
        "@nestjs/cache-manager": "2.2.2",
        "@nestjs/common": "10.3.9",
        "@nestjs/config": "3.2.2",
        "@nestjs/core": "10.3.9",
        "@nestjs/jwt": "10.2.0",
        "@nestjs/platform-express": "10.3.9",
        "@nestjs/swagger": "7.3.1",
        "cache-manager": "5.6.1",
        "class-transformer": "0.5.1",
        "class-validator": "0.14.1",
        "helmet": "7.1.0",
        "reflect-metadata": "0.2.2",
        "rxjs": "7.8.1",
        "swagger-ui-express": "5.0.1"
    },
    "devDependencies": {
        "@nestjs/cli": "10.3.2",
        "@nestjs/schematics": "10.1.1",
        "@nestjs/testing": "10.3.9",
        "@types/express": "4.17.21",
        "@types/jest": "29.5.12",
        "@types/node": "20.14.2",
        "@types/supertest": "6.0.2",
        "@typescript-eslint/eslint-plugin": "7.7.0",
        "@typescript-eslint/parser": "7.7.0",
        "eslint": "8.56.0",
        "eslint-config-prettier": "9.1.0",
        "eslint-plugin-prettier": "5.1.3",
        "jest": "29.7.0",
        "prettier": "3.3.2",
        "source-map-support": "0.5.21",
        "supertest": "7.0.0",
        "ts-jest": "29.1.4",
        "ts-loader": "9.5.1",
        "ts-node": "10.9.2",
        "tsconfig-paths": "4.2.0",
        "typescript": "5.4.5"
    },
    "scripts": {
        "restore": "npm install",
        "style:check": "npx prettier 'src/**/*.{js,ts,json}' 'test/**/*.{js,ts,json}' --config .prettierrc --check",
        "style:fix": "npx prettier 'src/**/*.{js,ts,json}' 'test/**/*.{js,ts,json}' --config .prettierrc --write",
        "lint:check": "npx eslint src test --ext .ts",
        "lint:fix": "npx eslint src test --ext .ts --fix",
        "check": "npm run style:check && npm run lint:check",
        "fix": "npm run style:fix && npm run lint:fix",
        "start": "nest start --watch --debug",
        "test": "jest",
        "build": "nest build"
    },
    "jest": {
        "testRegex": ".spec.ts",
        "transform": {
            ".ts": "ts-jest"
        }
    }
}
